<?xml version="1.0" encoding="UTF-8"?>
<!--
  Z-Tools Portfolio Manifest for Google Git Repo Tool

  This manifest file defines all projects in the z-tools ecosystem.
  It should be placed in: manifests/default.xml in the z-tools repository
  on the 'manifest' branch.

  USAGE:
  ------

  Initial Setup:
    $ mkdir ~/z-tools-workspace && cd ~/z-tools-workspace
    $ repo init -u git@github.com:pilakkat1964/z-tools.git -b manifest -m manifests/default.xml
    $ repo sync

  Sync All Projects:
    $ repo sync

  Sync Specific Groups:
    $ repo sync -g python      # Python projects only
    $ repo sync -g rust        # Rust projects only

  Create Feature Branch:
    $ repo start feature/my-feature

  See Project Status:
    $ repo status
    $ repo branches
    $ repo list

  Run Commands Across Projects:
    $ repo forall -c git log --oneline -1
    $ repo forall -g python -c pytest

  GROUPS:
  -------
  - manifests: Manifest repository (z-tools)
  - python: Python projects (z-edit, z-open)
  - rust: Rust projects (z-kitty-launcher, z-rclone-mount-applete)
  - tools: All tool projects (all except manifests)
  - all: All projects (default)

-->

<manifest>

  <!--
    REMOTE DEFINITIONS
    Specifies where to fetch repositories from.
  -->

  <remote  name="github"
           fetch="https://github.com/pilakkat1964"
           review="github.com" />

  <!--
    DEFAULT SETTINGS
    Applied to all projects unless overridden.
    
    - remote: Which remote to use (github)
    - revision: Default branch to track (master)
    - sync-j: Parallel jobs for sync (4)
    - dest-branch: Where to push to (master)
  -->

  <default remote="github"
           revision="master"
           sync-j="4"
           dest-branch="master" />

  <!--
    =========================================================================
    MANIFEST REPOSITORY
    =========================================================================
    
    This is the z-tools repository on the manifest branch.
    It contains the manifest files and coordination documentation.
  -->

  <project path="."
           name="z-tools"
           remote="github"
           revision="manifest"
           groups="manifests"
           dest-branch="manifest">
    <annotation name="description" value="Manifest repository for z-tools portfolio" />
  </project>

  <!--
    =========================================================================
    PYTHON PROJECTS
    =========================================================================
    
    Group: python, tools
    Language: Python 3.11+
    Build Tool: uv, pip, CMake
    Package Manager: PyPI
  -->

  <project path="z-edit"
           name="z-edit"
           remote="github"
           revision="master"
           groups="python,tools">
    <annotation name="description" value="Smart file editor launcher with MIME detection" />
    <annotation name="language" value="python" />
    <annotation name="package-manager" value="pypi" />
  </project>

  <project path="z-open"
           name="z-open"
           remote="github"
           revision="master"
           groups="python,tools">
    <annotation name="description" value="Smart file opener with MIME detection and editor mapping" />
    <annotation name="language" value="python" />
    <annotation name="package-manager" value="pypi" />
  </project>

  <!--
    =========================================================================
    RUST PROJECTS
    =========================================================================
    
    Group: rust, tools
    Language: Rust
    Build Tool: Cargo
    Package Manager: Crates.io
    
    Note: z-rclone-mount-applete uses 'main' instead of 'master'
  -->

  <project path="z-kitty-launcher"
           name="z-kitty-launcher"
           remote="github"
           revision="master"
           groups="rust,tools">
    <annotation name="description" value="Terminal session manager for Kitty terminal emulator" />
    <annotation name="language" value="rust" />
    <annotation name="package-manager" value="crates.io" />
  </project>

  <project path="z-rclone-mount-applete"
           name="z-rclone-mount-applete"
           remote="github"
           revision="main"
           dest-branch="main"
           groups="rust,tools">
    <annotation name="description" value="RClone mount manager with system tray integration" />
    <annotation name="language" value="rust" />
    <annotation name="package-manager" value="crates.io" />
  </project>

</manifest>

<!-- 

MANIFEST SYNTAX REFERENCE
=========================

Remote Element:
  <remote name="NAME"
          fetch="BASE_URL"
          review="REVIEW_HOST" />
  
  Attributes:
  - name: Identifier for this remote
  - fetch: Base URL to fetch repositories from
  - review: Code review host (e.g., gerrit.example.com)

Default Element:
  <default remote="NAME"
           revision="BRANCH"
           sync-j="N"
           dest-branch="BRANCH" />
  
  Attributes:
  - remote: Which remote to use by default
  - revision: Which branch/tag/commit to track
  - sync-j: Number of parallel sync jobs
  - dest-branch: Target branch for pushing

Project Element:
  <project path="LOCAL_PATH"
           name="REPO_NAME"
           remote="REMOTE"
           revision="BRANCH"
           dest-branch="BRANCH"
           groups="GROUP1,GROUP2"
           clone-depth="N"
           upstream="BRANCH" />
  
  Attributes:
  - path: Where to clone locally (relative to workspace)
  - name: Repository name on the server
  - remote: Which remote definition to use
  - revision: Branch/tag/commit to track
  - dest-branch: Where to push (if different from revision)
  - groups: Comma-separated group names (for selective ops)
  - clone-depth: Shallow clone depth (1 for faster clones)
  - upstream: Upstream branch for tracking (optional)

Annotation Element:
  <annotation name="KEY" value="VALUE" />
  
  Metadata for documentation purposes.
  Common annotations:
  - description: Project description
  - language: Programming language
  - package-manager: Where package is published
  - maintainer: Project maintainer
  - status: active, deprecated, experimental

Include Element (for modularity):
  <include name="manifests/subdir/partial.xml" />
  
  Include other manifest files.

-->
